{
  "MongoDB": {
    "ConnectionString": "mongodb://${MONGO_USER}:${MONGO_PASS}@mongo:27017/${MONGO_DB}?authSource=admin",
    "DatabaseName": "playhub"
  },
  "Jwt": {
    "Key": "playhub-super-secret-jwt-key-must-be-at-least-32-chars!",
    "Issuer": "playhub",
    "Audience": "playhub"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MongoDB.Driver": "Warning"
    }
  },
  "AllowedHosts": "*"
}
