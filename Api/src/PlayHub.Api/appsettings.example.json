{
  "MongoDB": {
    "ConnectionString": "mongodb://username:password@mongo:27017/playhub?authSource=admin",
    "DatabaseName": "playhub"
  },
  "Jwt": {
    "Key": "YOUR_SUPER_SECRET_JWT_KEY_MIN_32_CHARS",
    "Issuer": "playhub",
    "Audience": "playhub"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MongoDB.Driver": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowInMinutes": 1,
    "QueueLimit": 0
  }
}
